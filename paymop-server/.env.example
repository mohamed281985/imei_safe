# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-email@project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY should be provided only in production via environment variables

# Paymob Configuration
# PAYMOB_API_KEY=set_in_production_only
# PAYMOB_INTEGRATION_ID=set_in_production_only
# PAYMOB_IFRAME_ID=set_in_production_only
# PAYMOB_HMAC_SECRET=set_in_production_only

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=set_in_production_only

# Encryption
# ENCRYPTION_KEY=generate_new_key_in_production

# API Keys
# RESEND_API_KEY=set_in_production_only
# RECAPTCHA_SECRET=set_in_production_only

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development

# Session Secret
SESSION_SECRET=change-this-to-random-string-in-production

# CORS Origins
CLIENT_ORIGINS=http://localhost:8080,http://localhost:8081,https://imei-safe.me

# Rate Limiting (optional overrides)
# GLOBAL_RATE_MAX=100
# GLOBAL_RATE_WINDOW_MS=60000
# PAYMENT_RATE_MAX=5
# CREATE_APP_USER_MAX=5
